# SinnerTracker — Environment Variables
# Copia questo file in `.env` (NON committare .env)

# ── Supabase ──
SUPABASE_URL=https://czcszeoylcelgtduijqc.supabase.co
SUPABASE_SERVICE_ROLE_KEY=        # PRIVATA — solo backend/scraper
# La SUPABASE_ANON_KEY e' nel frontend (data.js), non serve qui

# ── RapidAPI (SportScore) ──
RAPIDAPI_KEY=                     # PRIVATA — solo scraper

# ── GCP (per il deploy) ──
GCP_PROJECT_ID=ai-agency-eu
GCP_REGION=europe-west8
